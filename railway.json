{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd website-update && npm ci --legacy-peer-deps && npm run build"
  },
  "deploy": {
    "startCommand": "cd website-update && npm run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
